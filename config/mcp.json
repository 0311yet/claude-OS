{
  "mcpServers": {
    "playwright": {
      "command": "cmd",
      "args": ["/c", "npx", "@playwright/mcp@latest"]
    },
    "serpapi": {
      "command": "node",
      "args": ["${configDir}/mcp_servers/serpapi/index.js"],
      "env": {
        "SERPAPI_API_KEY": "${secrets.SERPAPI_API_KEY}"
      }
    }
  }
}
